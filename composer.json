{
    "name": "whilesmart/eloquent-products",
    "description": "Polymorphic product and service catalog for Laravel applications.",
    "type": "library",
    "license": "MIT",
    "authors": [
        { "name": "Whilesmart Team" }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0",
        "whilesmart/eloquent-invoices": "*"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Whilesmart\\Products\\": "src/",
            "Whilesmart\\Products\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Whilesmart\\Products\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Whilesmart\\Products\\ProductsServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
